# Copy to .env and fill in real values. Never commit the real .env file.

NODE_ENV=production

# Bind address/port. Keep HOST=127.0.0.1 always — public exposure happens via
# the NGINX TLS reverse proxy (deploy/nginx/vps-console.conf) or an SSH tunnel,
# never by binding this process to a public interface directly.
HOST=127.0.0.1
PORT=6000

# SQLite database file (directory must be writable by the vps-console service user).
DB_PATH=./data/vps-console.db

# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=changeme-generate-a-64-byte-random-hex-secret
JWT_REFRESH_SECRET=changeme-generate-a-different-64-byte-random-hex-secret

# AES-256-GCM key for encrypting TOTP secrets at rest. Must be exactly 32 bytes hex (64 hex chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENC_KEY=changeme-generate-a-32-byte-random-hex-key

ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Cookie attributes for the refresh-token cookie.
COOKIE_DOMAIN=localhost
COOKIE_SECURE=true

# Root directory for the file-transfer jail. Must exist and be writable by the service user.
JAIL_ROOT=./data/jail

# Directory containing the root-owned helper scripts this app invokes via sudo.
# In production this is an absolute path like /opt/vps-console/helpers (see deploy/).
HELPER_SCRIPTS_DIR=../backend/scripts

# Comma-separated whitelist of systemd unit names the "service" catalog actions
# are allowed to control/inspect. Keep this narrow.
ALLOWED_SERVICE_UNITS=nginx,mosquitto,wg-quick@wg0,ssh

# CORS origin for the frontend dev server (Vite). Not used in production single-origin deploys.
DEV_CORS_ORIGIN=http://localhost:6001
